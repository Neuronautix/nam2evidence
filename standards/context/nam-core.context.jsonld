{
  "@context": {
    "@version": 1.1,
    "nam": "https://w3id.org/nam-core/0.1/",
    "nam-project": "https://w3id.org/nam-core/project/",
    "prov": "http://www.w3.org/ns/prov#",
    "schema": "http://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "obo": "http://purl.obolibrary.org/obo/",
    "qudt": "http://qudt.org/schema/qudt/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "id": "@id",
    "type": "@type",
    "label": "dcterms:title",
    "description": "dcterms:description",
    "version": "dcterms:hasVersion",
    "createdAt": { "@id": "dcterms:created", "@type": "xsd:dateTime" },
    "updatedAt": { "@id": "dcterms:modified", "@type": "xsd:dateTime" },
    "validationStatus": "nam:validationStatus",

    "EvidencePackage": "nam:EvidencePackage",
    "Project": "nam:Project",
    "ContextOfUse": "nam:ContextOfUse",
    "NAMStudy": "nam:NAMStudy",
    "BiologicalSystem": "nam:BiologicalSystem",
    "Donor": "nam:Donor",
    "CellSource": "nam:CellSource",
    "Platform": "nam:Platform",
    "Device": "nam:Device",
    "Assay": "nam:Assay",
    "Sample": "nam:Sample",
    "Exposure": "nam:Exposure",
    "EndpointMeasurement": "nam:EndpointMeasurement",
    "QCResult": "nam:QCResult",
    "ValidationEvidence": "nam:ValidationEvidence",
    "EvidenceClaim": "nam:EvidenceClaim",
    "ProvenanceActivity": "prov:Activity",
    "RawDataFile": "prov:Entity",
    "AnalysisScript": "prov:Entity",
    "OntologyMapping": "nam:OntologyMapping",

    "project": "nam:project",
    "contextOfUse": "nam:contextOfUse",
    "decisionQuestion": "nam:decisionQuestion",
    "intendedUse": "nam:intendedUse",
    "biologicalDomain": "nam:biologicalDomain",
    "regulatorySupportLevel": "nam:regulatorySupportLevel",
    "modelSystemType": "nam:modelSystemType",
    "species": { "@id": "nam:species", "@type": "@id" },
    "anatomy": { "@id": "nam:anatomy", "@type": "@id" },
    "cellType": { "@id": "nam:cellType", "@type": "@id" },
    "testArticle": { "@id": "nam:testArticle", "@type": "@id" },
    "endpoint": { "@id": "nam:endpoint", "@type": "@id" },
    "unit": { "@id": "nam:unit", "@type": "@id" },
    "value": "nam:value",
    "timepointValue": "nam:timepointValue",
    "timepointUnit": "nam:timepointUnit",

    "wasDerivedFrom": { "@id": "prov:wasDerivedFrom", "@type": "@id" },
    "wasGeneratedBy": { "@id": "prov:wasGeneratedBy", "@type": "@id" },
    "wasAssociatedWith": { "@id": "prov:wasAssociatedWith", "@type": "@id" },
    "used": { "@id": "prov:used", "@type": "@id" },
    "generatedAtTime": { "@id": "prov:generatedAtTime", "@type": "xsd:dateTime" },

    "measurements": { "@id": "nam:hasMeasurement", "@type": "@id", "@container": "@set" },
    "claims": { "@id": "nam:hasClaim", "@type": "@id", "@container": "@set" },
    "supportedBy": { "@id": "nam:supportedBy", "@type": "@id", "@container": "@set" },
    "reviewStatus": "nam:reviewStatus"
  }
}
