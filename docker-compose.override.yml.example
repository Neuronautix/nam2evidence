# Copy to docker-compose.override.yml to enable hot-reload development
# of the frontend with bind-mounted source.
#
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose up
#
# Compose merges override files automatically — no extra flags needed.

services:
  # Run the frontend dev server with the official node image instead of the
  # production multi-stage build. Source is bind-mounted for hot reload.
  # Note: this overrides the `build:` block from docker-compose.yml entirely,
  # because `image:` takes precedence when both are present and no build is
  # actually performed.
  frontend:
    image: node:20-alpine
    working_dir: /app
    command: sh -c "npm install && npm run dev"
    environment:
      NODE_ENV: development
      NEXT_PUBLIC_API_URL: "http://localhost:8080/api"
    volumes:
      - ./frontend:/app:cached
      - frontend_node_modules:/app/node_modules

volumes:
  frontend_node_modules:
